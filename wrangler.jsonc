{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "minecraft-biome-colors",
  "main": "src/index.js",
  "compatibility_date": "2026-07-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // per-version colormap JSON; create: wrangler kv namespace create COLORMAPS
  "kv_namespaces": [
    { "binding": "COLORMAPS", "id": "8c11efe0a4d04858b3bff6c0a1b0e3af" }
  ],

  // colormap PNGs keyed by sha256; create: wrangler r2 bucket create colormap-textures
  "r2_buckets": [
    { "binding": "TEXTURES", "bucket_name": "colormap-textures" }
  ]
}
